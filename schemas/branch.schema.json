{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Branch",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "project_id",
    "title",
    "description",
    "origin_decision_node_id",
    "root_node_id",
    "state",
    "parent_branch_id",
    "cloned_from_branch_id",
    "reactivated_from_branch_id",
    "comparison_tags",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z]+_[a-f0-9]{12}$"
    },
    "project_id": {
      "type": "string",
      "pattern": "^[a-z]+_[a-f0-9]{12}$"
    },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "origin_decision_node_id": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "root_node_id": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "state": {
      "type": "string",
      "enum": [
        "active",
        "explored",
        "discarded",
        "pending",
        "failed",
        "approved",
        "archived"
      ]
    },
    "parent_branch_id": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "cloned_from_branch_id": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "reactivated_from_branch_id": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "comparison_tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "created_at": { "type": "string", "minLength": 1 },
    "updated_at": { "type": "string", "minLength": 1 }
  }
}
